# --- XMPP client connection (required) -------------------------------------
# Bare JID and password of the service account the MCP server logs in as.
XMPP_JID=bot@example.com
XMPP_PASSWORD=change-me

# Connect host/port. Set XMPP_HOST only if it differs from the JID domain
# (common with Openfire/M-Link lab setups). Port defaults to 5222.
#XMPP_HOST=xmpp.example.com
#XMPP_PORT=5222

# Skip TLS certificate verification. Lab / self-signed servers ONLY.
#XMPP_TLS_INSECURE=false

# Default nickname used when joining MUC rooms.
#XMPP_NICK=xmpp-mcp

# Session establishment timeout (seconds) and inbound message buffer size.
#XMPP_CONNECT_TIMEOUT=30
#XMPP_INBOX_SIZE=500

# --- Openfire REST API admin (optional) -------------------------------------
# Leave unset to disable the of_* admin tools. Requires the Openfire
# "REST API" plugin to be installed and enabled on the server.
#OPENFIRE_BASE_URL=http://openfire.example.com:9090

# Authenticate with EITHER a shared secret key...
#OPENFIRE_SECRET_KEY=your-rest-api-secret

# ...OR an admin username + password.
#OPENFIRE_ADMIN_USER=admin
#OPENFIRE_ADMIN_PASSWORD=change-me

# Verify TLS certs on Openfire REST calls (set false for self-signed).
#OPENFIRE_VERIFY_TLS=true
